{
  "name": "sustainable-fsa-site",
  "version": "1.0.0",
  "private": true,
  "description": "Build pipeline (Tailwind CSS) for the Sustainable FSA Jekyll site.",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./assets/tailwind.css --watch",
    "lint:html": "html-validate '_layouts/**/*.html' '_includes/**/*.html'",
    "lint:data": "node scripts/validate-projects.mjs"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "html-validate": "^11.5.0",
    "js-yaml": "^4.2.0",
    "tailwindcss": "^3.4.0"
  }
}
